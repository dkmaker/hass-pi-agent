{
  "domain": "derivative",
  "storage_key": "core.config_entries",
  "storage_type": "config_entry",
  "name": "Derivative",
  "integration_type": "helper",
  "documentation": "https://www.home-assistant.io/integrations/derivative",
  "create_fields": [
    {
      "field": "name",
      "required": true,
      "type": "string"
    },
    {
      "field": "source",
      "required": true,
      "type": "unknown",
      "raw": "entity_selector"
    },
    {
      "field": "round",
      "required": true,
      "type": "number",
      "minimum": 0.0,
      "maximum": 6.0,
      "default": 2
    },
    {
      "field": "time_window",
      "required": true,
      "type": "object",
      "format": "duration"
    },
    {
      "field": "unit_prefix",
      "required": false,
      "type": "string",
      "format": "select"
    },
    {
      "field": "unit_time",
      "required": true,
      "type": "string",
      "format": "select",
      "default": "UnitOfTime.HOURS"
    },
    {
      "field": "max_sub_interval",
      "required": false,
      "type": "object",
      "format": "duration"
    }
  ],
  "update_fields": [
    {
      "field": "source",
      "required": true,
      "type": "unknown",
      "raw": "entity_selector"
    },
    {
      "field": "round",
      "required": true,
      "type": "number",
      "minimum": 0.0,
      "maximum": 6.0,
      "default": 2
    },
    {
      "field": "time_window",
      "required": true,
      "type": "object",
      "format": "duration"
    },
    {
      "field": "unit_prefix",
      "required": false,
      "type": "string",
      "format": "select"
    },
    {
      "field": "unit_time",
      "required": true,
      "type": "string",
      "format": "select",
      "default": "UnitOfTime.HOURS"
    },
    {
      "field": "max_sub_interval",
      "required": false,
      "type": "object",
      "format": "duration"
    }
  ]
}
