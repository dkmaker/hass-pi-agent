      "required": true,
      "type": "string",
      "format": "time"
    },
    {
      "field": "before_time",
      "required": true,
      "type": "string",
      "format": "time"
    }
  ],
  "update_fields": [
    {
      "field": "after_time",
      "required": true,
      "type": "string",
      "format": "time"
    },
    {
      "field": "before_time",
      "required": true,
      "type": "string",
      "format": "time"
    }
  ]
}
