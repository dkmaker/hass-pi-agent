{
  "domain": "utility_meter",
  "storage_key": "core.config_entries",
  "storage_type": "config_entry",
  "name": "Utility Meter",
  "integration_type": "helper",
  "documentation": "https://www.home-assistant.io/integrations/utility_meter",
  "create_fields": [
    {
      "field": "name",
      "required": true,
      "type": "string"
    },
    {
      "field": "source_sensor",
      "required": true,
      "type": "string",
      "format": "entity_id"
    },
    {
      "field": "cycle",
      "required": true,
      "type": "string",
      "format": "select"
    },
    {
      "field": "meter_offset",
      "required": true,
      "type": "number",
      "minimum": 0.0,
      "maximum": 28.0,
      "default": 0
    },
    {
      "field": "tariffs",
      "required": true,
      "type": "string",
      "format": "select",
      "default": []
    },
    {
      "field": "meter_net_consumption",
      "required": true,
      "type": "boolean",
      "default": false
    },
    {
      "field": "meter_delta_values",
      "required": true,
      "type": "boolean",
      "default": false
    },
    {
      "field": "meter_periodically_resetting",
      "required": true,
      "type": "boolean",
      "default": [
        true
      ]
    },
    {
      "field": "sensor_always_available",
      "required": false,
      "type": "boolean",
      "default": [
        false
      ]
    }
  ],
  "update_fields": [
    {
      "field": "source_sensor",
      "required": true,
      "type": "string",
      "format": "entity_id"
    },
    {
      "field": "meter_periodically_resetting",
      "required": true,
      "type": "boolean",
      "default": ""
    },
    {
      "field": "sensor_always_available",
      "required": false,
      "type": "boolean",
      "default": [
        false
      ]
    }
  ]
}
