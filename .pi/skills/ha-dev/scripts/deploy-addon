#!/usr/bin/env bash
#
# Deploy the Pi Agent add-on to the HAOS dev VM via SCP.
#
# The VM does not have rsync, so we use scp to copy files.
# Local addons go into /addons/<folder>/ on the VM (SSH path).
# The Supervisor scans this directory on `ha store reload`.
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../../../.." && pwd)"
source "$REPO_ROOT/.env"

ADDON_DIR="$REPO_ROOT/addon"
NET_NAME="${HAOS_NET_NAME:-haos-isolated}"
ADDON_SLUG="pi_agent"

VM_IP=$(sudo virsh net-dhcp-leases "$NET_NAME" 2>/dev/null | grep -oP '10\.99\.0\.\d+' | head -1)
if [ -z "$VM_IP" ]; then
  echo "ERROR: Cannot find VM IP. Is the VM running?"
  echo "  .pi/skills/ha-dev/scripts/vm-ctl start"
  exit 1
fi

SSH_OPTS="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR"
SSH_CMD="ssh $SSH_OPTS root@${VM_IP}"

echo "==> VM IP: $VM_IP"
echo "==> Testing SSH..."
if ! $SSH_CMD echo "SSH OK" 2>/dev/null; then
  echo "ERROR: Cannot SSH to HAOS VM at root@${VM_IP}:22"
  echo "Ensure the Terminal & SSH add-on is installed, configured, and port 22 is mapped."
  exit 1
fi

echo "==> Syncing extension source into addon build context..."
rm -rf "$ADDON_DIR/extensions/home-assistant"
mkdir -p "$ADDON_DIR/extensions"
cp -a "$REPO_ROOT/.pi/extensions/home-assistant" "$ADDON_DIR/extensions/home-assistant"
rm -rf "$ADDON_DIR/extensions/home-assistant/node_modules" "$ADDON_DIR/extensions/home-assistant/data"

echo "==> Cleaning remote /addons/${ADDON_SLUG}/"
$SSH_CMD "rm -rf /addons/${ADDON_SLUG} && mkdir -p /addons/${ADDON_SLUG}"

echo "==> Copying addon/ → VM:/addons/${ADDON_SLUG}/"
scp -r $SSH_OPTS "$ADDON_DIR/"* "root@${VM_IP}:/addons/${ADDON_SLUG}/"

echo "==> Reloading add-on store..."
$SSH_CMD 'ha store reload' 2>/dev/null || true

echo ""
echo "Done! Add-on synced to VM."
echo ""
echo "First time:"
echo "  http://${VM_IP}:8123 → Settings → Add-ons → Add-on Store → Local add-ons"
echo "  → Pi Agent for Home Assistant → Install"
echo ""
echo "After code changes:"
echo "  .pi/skills/ha-dev/scripts/deploy-addon"
echo "  .pi/skills/ha-dev/scripts/ha-supervisor addon-rebuild local_${ADDON_SLUG}"
echo ""
echo "Check logs:"
echo "  .pi/skills/ha-dev/scripts/ha-api addon-logs local_${ADDON_SLUG}"
